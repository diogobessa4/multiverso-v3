# Porta do servidor (opcional, padrão: 3001)
PORT=3001

# Senha do painel admin — defina uma senha forte aqui antes de iniciar
ADMIN_PASSWORD=sua-senha-forte-aqui

# Origem(ns) permitida(s) no CORS — OBRIGATÓRIO. Sem fallback para "*".
# Aceita múltiplas origens separadas por vírgula.
CORS_ORIGIN=http://localhost:5500
